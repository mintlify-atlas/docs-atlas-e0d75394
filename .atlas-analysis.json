  "keyFeatures": [
    "Tree-structured lifecycle-aware business logic components (BLoCs)",
    "Multiple navigation models: Child Stack, Child Slot, Child Pages, Child Panels, Child Items",
    "Pluggable UI — Jetpack/Multiplatform Compose, SwiftUI, Kotlin/React, Android Views",
    "Kotlin Multiplatform support: Android, iOS, Desktop (JVM), Web (JS/Wasm), macOS, tvOS, watchOS",
    "State preservation via kotlinx-serialization across all platforms",
    "Instance retaining (ViewModel equivalent) with InstanceKeeper",
    "Back button handling with predictive back gesture support",
    "Generic/custom navigation model API for advanced use cases",
    "Dependency injection via constructor with type-safe configurations",
    "Unit-testable business logic without UI instrumentation"
  ],
  "publicApiSurface": [
    "ComponentContext",
    "DefaultComponentContext",
    "ChildStack / StackNavigation / childStack()",
