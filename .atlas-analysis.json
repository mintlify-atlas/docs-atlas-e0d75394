    "ChildPages / PagesNavigation / childPages()",
    "ChildPanels / PanelsNavigation / childPanels()",
    "ChildItems / ItemsNavigation / childItems()",
    "Value / MutableValue",
    "Lifecycle / LifecycleRegistry",
    "StateKeeper / stateKeeper",
    "InstanceKeeper / instanceKeeper / retainedInstance()",
    "BackHandler / BackDispatcher / BackCallback",
    "defaultComponentContext() (Android)",
    "LifecycleController (Desktop Compose)",
    "Children() / ChildStack() composables (Compose extensions)",
    "subscribeAsState() (Compose extensions)",
    "stackAnimation() / fade() / slide() / scale()",
    "predictiveBackAnimation() / PredictiveBackParams",
    "childContext()",
    "retainedComponent() (Android)"
  ]
